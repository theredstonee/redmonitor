# Postgres
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=redmonitor_backend
PG_USER=redmonitor
PG_PASS=replace-me

# Server-side encryption key for pgcrypto pgp_sym_encrypt
SERVER_ENC_KEY=replace-me-64-hex

# Salt mixed into the hardware-fingerprint hash to derive device-id
DEVICE_ID_SALT=replace-me-64-hex

# Admin session cookie signing
SESSION_SECRET=replace-me-32-hex

# Bootstrap admin on first start (idempotent if user already exists)
ADMIN_USERNAME=theredstonee
ADMIN_PASSWORD_INITIAL=replace-me-on-first-launch

# Nitro/Nuxt listen
NITRO_PORT=3210
NITRO_HOST=127.0.0.1
